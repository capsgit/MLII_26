{
  "input_path": "data/data.csv",
  "output_path": "data/cleaned_data.csv",
  "log_path": "logs/cleaning.log",

  "steps": [
    { "name": "drop_empty_rows" },
    {
      "name": "remove_repeated_header_rows",
      "column": "Order ID",
      "header_value": "Order ID"
    },
    { "name": "cast_numeric", "columns": ["Quantity Ordered", "Price Each"] },
    { "name": "cast_datetime", "column": "Order Date" },
    { "name": "drop_na_after_cast" },
    { "name": "drop_duplicates" }
  ],

  "logging": {
    "version": 1,
    "formatters": {
      "simple": {
        "format": "%(asctime)s | %(levelname)s | %(message)s"
      }
    },

    "handlers": {
      "console": {
        "class": "logging.StreamHandler",
        "level": "INFO",
        "formatter": "simple"
      },

      "file": {
        "class": "logging.FileHandler",
        "level": "INFO",
        "formatter": "simple",
        "filename": "logs/cleaning.log",
        "encoding": "utf-8"
      }
    },

    "loggers": {
      "data_cleaner": {
        "handlers": ["console", "file"],
        "level": "INFO"
      }
    }
  }
}
